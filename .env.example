# Trello: generate at https://trello.com/power-ups/admin
TRELLO_API_KEY=
TRELLO_TOKEN=

# Comma-separated Trello board IDs to sync (find in board URL: trello.com/b/<board_id>/...)
TRELLO_BOARD_IDS=

# Dust: workspace API key + IDs of the target space and data source
DUST_API_KEY=
DUST_WORKSPACE_ID=
DUST_SPACE_ID=
DUST_DATASOURCE_ID=
DUST_API_URL=https://dust.tt/api

# A card with no activity for this many days is flagged "stale" in the board digest.
STALE_DAYS_THRESHOLD=7

# Number of most recent comments to include per card document.
COMMENTS_PER_CARD=5
